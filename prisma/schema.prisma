model Session {
  id           Int     @id @default(autoincrement())
  bodyweight   Int?
  weight_class String?
  division     String?
  coefficient  String?
  bestSquat    Int
  bestBench    Int
  bestDeadlift Int
  total        Int
  wilks_score  Int?
  dots_score   Int?
  placement    Int?
  meet_entry   Int
  // attempt      Attempt[]
}

model Attempt {
  id             Int     @id @default(autoincrement())
  // session        Session @relation(fields: [sessionId], references: [id])
  // sessionId      Int
  lift_type      String
  attempt_number Int
  weight         Int
  left_judge     Boolean @default(false)
  center_judge   Boolean @default(false)
  right_judge    Boolean @default(false)
  result         Boolean @default(false)
  platform_pr    Boolean @default(false)
  all_time_pr    Boolean @default(false)
}
